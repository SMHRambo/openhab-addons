<?xml version="1.0" encoding="UTF-8"?>
<thing:thing-descriptions bindingId="rollershutterautomation"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xmlns:thing="https://openhab.org/schemas/thing-description/v1.0.0"
	xsi:schemaLocation="https://openhab.org/schemas/thing-description/v1.0.0 https://openhab.org/schemas/thing-description-1.0.0.xsd">

	<bridge-type id="controller">
		<label>Controller</label>
		<description>TODO</description>
	</bridge-type>

	<thing-type id="rollershutter">
		<label>Rollershutter</label>
		<description>TODO</description>
		<channels>
			<channel typeId="rollershutter" id="rollershutter"/>
			<channel typeId="sunprotection" id="sunprotection"></channel>
			<channel typeId="rainprotection" id="rainprotection"></channel>
			<channel typeId="openedsensor" id="openedsensor"></channel>
			<channel typeId="tiltedsensor" id="tiltedsensor"></channel>
			<channel typeId="closedsensor" id="closedsensor"></channel>
		</channels>

		<config-description>

			<parameter-group name="mainsettings">
				<label>Main settings</label>
				<description>Main settings</description>
			</parameter-group>
            <parameter-group name="windowsdoorsettings">
                <label>Windows/Door settings</label>
                <description>Window/Door settings</description>
            </parameter-group>
            <parameter-group name="sunprotectionsettings">
                <label>Sun protection settings</label>
                <description>Sun protection settings</description>
            </parameter-group>
            <parameter-group name="rainprotectionsettings">
                <label>Rain protection settings</label>
                <description>Rain protection settings.</description>
            </parameter-group>

            <parameter name="openingMode" type="text" required="false" readOnly="false" multiple="false" groupName="mainsettings">
              <default>off</default>
              <label>Opening mode</label>
              <description>Type of control for opening the shutter</description>
              <options>
                <option value="off">Off</option>
                <option value="livingarea">Living area</option>
                <option value="sleepingarea">Sleeping area</option>
                <option value="childrenarea">Children area</option>
                <option value="sunset">Sunset</option>
                <option value="sunrise">Sunrise</option>
                <option value="sunelevationabove">Sun elevation (Sunrise)</option>
                <option value="sunelevationbelow">Sun elevation (Sunset)</option>
                <option value="timeeveryday">Time everyday</option>
                <option value="timeworkdayweekend">Time workday/weekend</option>
                <option value="timeindividual">Time individual</option>
              </options>
            </parameter>
            <parameter name="closingMode" type="text" required="false" readOnly="false" multiple="false" groupName="mainsettings">
              <default>Off</default>
              <label>Closing mode</label>
              <description>Type of control for closing the shutter</description>
              <options>
                <option value="off">Off</option>
                <option value="livingarea">Living area</option>
                <option value="sleepingarea">Sleeping area</option>
                <option value="childrenarea">Children area</option>
                <option value="sunset">Sunset</option>
                <option value="sunrise">Sunrise</option>
                <option value="sunelevationabove">Sun elevation (Sunrise)</option>
                <option value="sunelevationbelow">Sun elevation (Sunset)</option>
                <option value="timeeveryday">Time everyday</option>
                <option value="timeworkdayweekend">Time workday/weekend</option>
                <option value="timeindividual">Time individual</option>
              </options>
            </parameter>
            <parameter name="openingHeight" type="integer" min="0" max="100" required="false" readOnly="false" multiple="false" groupName="mainsettings">
            	<default>0</default>
            	<label>Opening height</label>
            	<description>Roller shutter height when opening</description>
            </parameter>
            <parameter name="closingHeight" type="integer" min="0" max="100" required="false" readOnly="false" multiple="false" groupName="mainsettings">
              <default>100</default>
              <label>Closing height</label>
              <description>Roller shutter height when closing</description>
            </parameter>
            <parameter name="openingElevation" type="integer" min="-90" max="90" required="false" readOnly="false" multiple="false" groupName="mainsettings">
              <default>4</default>
              <label>Sun elevation for opening</label>
              <description>Sun elevation for opening mode</description>
            </parameter>
            <parameter name="closingElevation" type="integer" min="-90" max="90" required="false" readOnly="false" multiple="false" groupName="mainsettings">
              <default>4</default>
              <label>Sun elevation for closing</label>
              <description>Sun elevation for closing mode</description>
            </parameter>

            <parameter name="windowsdoorMode" type="text" required="false" readOnly="false" multiple="false" groupName="windowsdoorsettings">
              <default>off</default>
              <label>Window/Door mode</label>
              <description>Behavior when window/door is opened/closed</description>
              <options>
                <option value="off">Off</option>
                <option value="opening">Opening</option>
                <option value="closing">Closing</option>
                <option value="openingclosing">Opening and closing</option>
              </options>
            </parameter>
            <parameter name="lockoutprotection" type="text" required="false" readOnly="false" multiple="false" groupName="windowsdoorsettings">
              <default>off</default>
              <label>lock-out protection</label>
              <description>Behavior when window/door is opened/closed</description>
              <options>
                <option value="off">Off</option>
                <option value="opening">Opening</option>
                <option value="closing">Closing</option>
                <option value="openingclosing">Opening and closing</option>
              </options>
            </parameter>
            <parameter name="openedHeight" type="integer" min="0" max="100" required="false" readOnly="false" multiple="false" groupName="windowsdoorsettings">
              <default>100</default>
              <label>Opened height</label>
              <description>Roller shutter height when windows/door is opened</description>
            </parameter>
            <parameter name="tiltedHeight" type="integer" min="0" max="100" required="false" readOnly="false" multiple="false" groupName="windowsdoorsettings">
              <default>100</default>
              <label>Tilted height</label>
              <description>Roller shutter height the window/door is tilted</description>
            </parameter>
            <parameter name="sensorValueOpened" type="text" required="false" readOnly="false" multiple="false" groupName="windowsdoorsettings">
              <label>Sensor value opened</label>
              <description>Value of the window/door sensor when it is opened</description>
            </parameter>
            <parameter name="sensorValueTilted" type="text" required="false" readOnly="false" multiple="false" groupName="windowsdoorsettings">
              <label>Sensor value tilted</label>
              <description>Value of the window/door sensor when it is tilted</description>
            </parameter>
            <parameter name="sensorValueClosed" type="text" required="false" readOnly="false" multiple="false" groupName="windowsdoorsettings">
              <label>Sensor value closed</label>
              <description>Value of the window/door sensor when it is closed</description>
            </parameter>

		    <parameter name="sunprotectionMode" type="text" required="false" readOnly="false" multiple="false" groupName="sunprotectionsettings">
		      <default>off</default>
		      <label>Sun Protection Mode</label>
		      <description>String</description>
		      <options>
		        <option value="off">Off</option>
		        <option value="direction">Direction</option>
		        <option value="external">External</option>
		        <option value="directionexternal">Direction and external</option>
		      </options>
		    </parameter>
            <parameter name="sunAzimuthAngleLeft" type="integer" min="0" max="359" required="false" readOnly="false" multiple="false" groupName="sunprotectionsettings">
                <label>Sun Azimuth Angle Left</label>
                <default>180</default>
                <description>Sun azimuth angle threshold in degrees (0-359)</description>
            </parameter>
            <parameter name="sunAzimuthAngleRight" type="integer" min="0" max="359" required="false" readOnly="false" multiple="false" groupName="sunprotectionsettings">
                <label>Sun Azimuth Angle Right</label>
                <default>180</default>
                <description>Sun azimuth angle threshold in degrees (0-359)</description>
            </parameter>
			<parameter name="sunHeight" type="integer" min="0" max="100" required="false" readOnly="false" multiple="false" groupName="sunprotectionsettings">
				<label></label>
				<default>180</default>
				<description>Roller shutter height when window/door is tilted and it is raining</description>
			</parameter>

			<parameter name="rainprotectionMode" type="text" required="false" groupName="rainprotectionsettings">
				<label>Rain Protection Enabled</label>
				<default>false</default>
				<description>Enable/disable rain protection mode</description>
			</parameter>
		</config-description>
	</thing-type>

	<channel-type id="rollershutter">
		<item-type>Rollershutter</item-type>
		<label>Rollershutter</label>
		<description>Rollershutter to control</description>
	</channel-type>
	<channel-type id="sunprotection">
		<item-type>Switch</item-type>
		<label>Sun protection trigger</label>
	</channel-type>
	<channel-type id="rainprotection">
		<item-type>Switch</item-type>
		<label>Rain protection trigger</label>
	</channel-type>
	<channel-type id="openedsensor">
		<item-type>String</item-type>
		<label>Sensor for opend windows/door</label>
	</channel-type>
	<channel-type id="tiltedsensor">
		<item-type>String</item-type>
		<label>Sensor for tilted windows/door</label>
	</channel-type>
    <channel-type id="closedsensor">
        <item-type>String</item-type>
        <label>Sensor for closed windows/door</label>
    </channel-type>

</thing:thing-descriptions>
